# -*- mode: Shell-script -*-

if  is-root ; then

  if ostree admin status 2>/dev/null >&2 ; then

    new-alias upgrade-preview "rpm-ostree upgrade --preview --bypass-driver"
    new-alias upgrade-status "rpm-ostree status --verbose"
    
    upgrade-pin() {
      ostree admin pin "${1:-1}"
    }
    upgrade-unpin() {
      ostree admin pin --unpin "${1:-2}"
    }

  fi
  
fi
