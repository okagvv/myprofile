# -*- shell-script -*-

is-fn() {
  declare -F "$1" >/dev/null
}

fn-temp() {
  if [[ $# -gt 0 && $# -le 2 ]] ; then
    local _dir _file
    _dir="${TMPDIR:-/tmp}/${script:-${FUNCNAME[1]}}"
    if [[ "$1" =~ ^-+c(leanup)?$ ]] ; then
      rm -rf "$_dir"
    else
      if [ $# -gt 1 ] ; then
        _file="$1"
        shift
      else
        _file="${FUNCNAME[1]:-log}"
      fi
      [ -d "$_dir" ] || mkdir -p "$_dir"
      mktemp --tmpdir="$_dir" --suffix=".$1" "$_file.XXXXX"
    fi
  else
    fn-usage "[--cleanup] [filename] suffix"
  fi
}

fn-loc() {
  if [ $# -gt 0 ] ; then
    shopt -s extdebug
    declare -F "$@" | sed -r 's~(^.+) ([[:digit:]]+) (.+)$~'"$([ $# -gt 1 ] && echo '\1:\3:\2' || echo '\3:\2')"'~;s~//~/~g'
    shopt -u extdebug
  else
    eval "fn-loc $(declare -F | cut -d' ' -f3 | tr '\n' ' ')"
  fi
}

script=

fn-parent() {
  local _parent _i

  if [ -n "$script" ] ; then

    _parent="$script"

  elif [ -n "$FUNCNAME" ] ; then

    for (( _i = 0 ; _i < ${#FUNCNAME[@]} ; _i++ )) ; do

      _parent="${FUNCNAME[$_i]}"
      [[ "$_parent" =~ ^fn- ]] && continue
      [[ "$_parent" =~ ^[[:alpha:]] ]] && break

    done
  fi

  echo -n "${_parent:-?}"
}

fn-colored() {
  echo -e "\e[${1%,*}m\e[${1#*,}m$2\e[0m"
}

fn-usage() {
  fn-colored 0,34 "Usage: $(fn-parent) $1" >&2
  return 2
}

fn-error() {
  fn-colored 1,31 "$(fn-parent): $1" >&2
  return 1
}

fn-info() {
  fn-colored 1,35 "$(fn-parent): $1"
}

fn_trace=
fn-trace() {
  [ -z "$fn_trace" ] || fn-colored 1,36 "$(fn-parent): $1" >&2
}

fn-vars() {
  fn-colored 1,34 "$(fn-parent): $(declare -p $@ | sed -r 's/(\[[[:digit:]]+\]=)/\n\1/g')" >&2
}

fn-abort() {
  if [ -z "$PS1" ] ; then

    # abort scripts or subshell functions
    fn-error "$1"
    exit "${2:-1}"

  else

    # work-around to abort (nested) functions
    local _origin="$(fn-parent)"
    eval "_fn-abort() { unset $_origin; : \"\${$_origin:?\$1}\"; }"
    _fn-abort "$1"

  fi
}

fn-logger() {
  logger --tag "$(fn-parent)" --priority "user.$1" "$2"
}

fn-export() {
  if [ $# -gt 0 ] ; then
    local _fn _scope
    for _scope in "$@" ; do
      if [ -f "$_scope" ] ; then
        for _fn in $(sed -rn 's/^([[:alpha:]_][[:alnum:]_-]+) *\(\).*$/\1/p' "$_scope") ; do
          export -f "$_fn"
        done
      else
        for _fn in $(declare -F | cut -d' ' -f3 | grep -E "$_scope") ; do
          export -f "$_fn"
        done
      fi
    done
  else
    fn-usage "{<regexp>}"
  fi
}

fn_xtrace=
fn-xtrace() {
  # Enable xtrace until return from calling function.
  fn_xtrace="${FUNCNAME[1]}"
  [ -n "$fn_xtrace" ] || return 0

  # ensure $PS4 has  value (for security reasons shells running as root do not inherit $PS4)
  export PS4="+ \${FUNCNAME[0]} \$LINENO: "

  fn_trace=y
  trap 'if [[ "$FUNCNAME" == "$fn_xtrace" ]] ; then set +x; trap - RETURN ERR; echo "-===- Stopped xtrace for $fn_xtrace() -===-" >&2; fn_xtrace=; fn_trace=; fi' RETURN
  trap 'set +x; fn_xtrace=; fn_trace=; trap - RETURN ERR' ERR

  echo "-===- Start xtrace for $fn_xtrace() -===-" >&2
  set -x
}
